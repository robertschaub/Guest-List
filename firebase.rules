rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function eventExists(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId));
    }

    function eventData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data;
    }

    function securityExists(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId)/private/security);
    }

    function securityData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/private/security).data;
    }

    function partnerLinkExists(eventId, partnerId) {
      return exists(/databases/$(database)/documents/events/$(eventId)/partnerLinks/$(partnerId));
    }

    function partnerLinkData(eventId, partnerId) {
      return get(/databases/$(database)/documents/events/$(eventId)/partnerLinks/$(partnerId)).data;
    }

    function adminSecurityExists() {
      return exists(/databases/$(database)/documents/appSecurity/admin);
    }

    function adminSecurityData() {
      return get(/databases/$(database)/documents/appSecurity/admin).data;
    }

    function isMember(eventId) {
      return signedIn()
        && exists(/databases/$(database)/documents/events/$(eventId)/members/$(request.auth.uid));
    }

    function memberData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/members/$(request.auth.uid)).data;
    }

    function validRole(role) {
      return role == 'admin' || role == 'checkin' || role == 'partner';
    }

    function mainAdminNameKey() {
      return 'main';
    }

    function adminMainPinMatchesForData(data, pinHash) {
      return data.adminPinHash == pinHash
        || (
          data.keys().hasAny(['adminPinHashes'])
          && pinHash in data.adminPinHashes
        );
    }

    function adminNamedPinMatchesForData(data, pinNameHash) {
      return pinNameHash is string
        && data.keys().hasAny(['adminNamedPinHashes'])
        && pinNameHash in data.adminNamedPinHashes;
    }

    function adminMasterNamedPinMatchesForData(data, pinNameHash) {
      return pinNameHash is string
        && data.keys().hasAny(['adminMasterNamedPinHashes'])
        && pinNameHash in data.adminMasterNamedPinHashes;
    }

    function validAdminMemberPinForData(data, pinHash, pinNameHash, displayNameKey) {
      return displayNameKey is string
        && (
          (
            displayNameKey == mainAdminNameKey()
            && adminMainPinMatchesForData(data, pinHash)
          )
          || (
            displayNameKey != mainAdminNameKey()
            && adminNamedPinMatchesForData(data, pinNameHash)
          )
        );
    }

    function validMasterAdminMemberPinForData(data, pinHash, pinNameHash, displayNameKey) {
      return displayNameKey is string
        && (
          (
            displayNameKey == mainAdminNameKey()
            && adminMainPinMatchesForData(data, pinHash)
          )
          || (
            displayNameKey != mainAdminNameKey()
            && adminMasterNamedPinMatchesForData(data, pinNameHash)
          )
        );
    }

    function validLegacyAdminMemberPin(eventId, pinHash, pinNameHash, displayNameKey) {
      return securityExists(eventId)
        && validAdminMemberPinForData(securityData(eventId), pinHash, pinNameHash, displayNameKey);
    }

    function validLegacyMasterAdminForData(data) {
      return data.authorizingEventId is string
        && isMember(data.authorizingEventId)
        && memberData(data.authorizingEventId).role == 'admin'
        && validLegacyAdminMemberPin(
          data.authorizingEventId,
          memberData(data.authorizingEventId).pinHash,
          memberData(data.authorizingEventId).pinNameHash,
          memberData(data.authorizingEventId).displayNameKey
        );
    }

    function validAdminPin(eventId, pinHash, pinNameHash, displayNameKey) {
      return (
          adminSecurityExists()
          && validAdminMemberPinForData(adminSecurityData(), pinHash, pinNameHash, displayNameKey)
        )
        || (
          !adminSecurityExists()
          && validLegacyAdminMemberPin(eventId, pinHash, pinNameHash, displayNameKey)
        );
    }

    function validCheckinPin(eventId, pinNameHash) {
      return securityExists(eventId)
        && pinNameHash is string
        && securityData(eventId).keys().hasAny(['checkinNamedPinHashes'])
        && pinNameHash in securityData(eventId).checkinNamedPinHashes;
    }

    function validPin(eventId, role, pinHash, pinNameHash, displayNameKey) {
      return (
          role == 'admin'
          && validAdminPin(eventId, pinHash, pinNameHash, displayNameKey)
        )
        || (
          role == 'checkin'
          && validCheckinPin(eventId, pinNameHash)
        );
    }

    function validPartnerCredentials(eventId, data) {
      return data.role == 'partner'
        && data.partnerId is string
        && data.partnerId.size() > 0
        && data.partnerTokenHash is string
        && data.partnerTokenHash.size() == 64
        && data.pinHash == ''
        && data.pinNameHash == ''
        && data.displayNameKey == data.partnerId
        && eventExists(eventId)
        && !eventHidden(eventId)
        && partnerLinkExists(eventId, data.partnerId)
        && partnerLinkData(eventId, data.partnerId).active == true
        && partnerLinkData(eventId, data.partnerId).expiresAt is timestamp
        && request.time < partnerLinkData(eventId, data.partnerId).expiresAt
        && data.partnerTokenHash == partnerLinkData(eventId, data.partnerId).tokenHash;
    }

    function hasCurrentPin(eventId) {
      return isMember(eventId)
        && (
          validPartnerCredentials(eventId, memberData(eventId))
          || (
            memberData(eventId).role != 'partner'
            && (
              validPin(eventId, memberData(eventId).role, memberData(eventId).pinHash, '', memberData(eventId).displayNameKey)
              || (
                memberData(eventId).keys().hasAny(['pinNameHash'])
                && validPin(eventId, memberData(eventId).role, memberData(eventId).pinHash, memberData(eventId).pinNameHash, memberData(eventId).displayNameKey)
              )
            )
          )
        );
    }

    function eventHidden(eventId) {
      return eventExists(eventId)
        && eventData(eventId).keys().hasAny(['hidden'])
        && eventData(eventId).hidden == true;
    }

    function hasMasterAdminPin(eventId) {
      return hasCurrentPin(eventId)
        && memberData(eventId).role == 'admin'
        && adminSecurityExists()
        && validMasterAdminMemberPinForData(
          adminSecurityData(),
          memberData(eventId).pinHash,
          memberData(eventId).pinNameHash,
          memberData(eventId).displayNameKey
        );
    }

    function isAdmin(eventId) {
      return hasCurrentPin(eventId)
        && memberData(eventId).role == 'admin';
    }

    function isPartner(eventId) {
      return hasCurrentPin(eventId)
        && memberData(eventId).role == 'partner';
    }

    function checkinAccessWindowOpen(eventId) {
      return eventExists(eventId)
        && !eventHidden(eventId)
        && eventData(eventId).keys().hasAll(['checkinAccessStartsAt', 'checkinAccessEndsAt'])
        && eventData(eventId).checkinAccessStartsAt is timestamp
        && eventData(eventId).checkinAccessEndsAt is timestamp
        && request.time >= eventData(eventId).checkinAccessStartsAt
        && request.time < eventData(eventId).checkinAccessEndsAt;
    }

    function isCheckin(eventId) {
      return isAdmin(eventId)
        || (
          hasCurrentPin(eventId)
          && memberData(eventId).role == 'checkin'
          && checkinAccessWindowOpen(eventId)
        );
    }

    function memberWriteAllowedForRole(eventId, role) {
      return role == 'admin'
        || role == 'partner'
        || (
          role == 'checkin'
          && checkinAccessWindowOpen(eventId)
        );
    }

    function sameNamedMember(eventId) {
      return isCheckin(eventId)
        && resource.data.role == memberData(eventId).role
        && resource.data.displayNameKey is string
        && resource.data.displayNameKey != ''
        && resource.data.displayNameKey == memberData(eventId).displayNameKey;
    }

    function sameNamedOtherMember(eventId, uid) {
      return signedIn()
        && uid != request.auth.uid
        && sameNamedMember(eventId);
    }

    function adminMemberDeviceLabelUpdateAllowed(eventId) {
      return isAdmin(eventId)
        && request.resource.data.deviceLabel is string
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'deviceLabel', 'updatedAt'
        ]);
    }

    function validMemberWrite(eventId, uid) {
      return signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && validRole(request.resource.data.role)
        && request.resource.data.pinHash is string
        && request.resource.data.pinNameHash is string
        && request.resource.data.displayNameKey is string
        && request.resource.data.displayName is string
        && request.resource.data.deviceLabel is string
        && (
          (
            request.resource.data.role == 'partner'
            && validPartnerCredentials(eventId, request.resource.data)
          )
          || (
            request.resource.data.role != 'partner'
            && !request.resource.data.keys().hasAny(['partnerId', 'partnerTokenHash'])
            && validPin(eventId, request.resource.data.role, request.resource.data.pinHash, request.resource.data.pinNameHash, request.resource.data.displayNameKey)
          )
        )
        && memberWriteAllowedForRole(eventId, request.resource.data.role)
        && request.resource.data.keys().hasOnly([
          'uid', 'role', 'pinHash', 'pinNameHash', 'displayNameKey',
          'displayName', 'deviceLabel', 'partnerId', 'partnerTokenHash',
          'createdAt', 'updatedAt'
        ]);
    }

    function validMemberCreate(eventId, uid) {
      return validMemberWrite(eventId, uid);
    }

    function validMemberSelfUpdate(eventId, uid) {
      return validMemberWrite(eventId, uid);
    }

    function validStatus(status) {
      return status == 'open' || status == 'checked_in';
    }

    function validSecurityData(data) {
      return (!data.keys().hasAny(['adminPinHash']) || data.adminPinHash is string)
        && (!data.keys().hasAny(['adminPinHashes']) || (data.adminPinHashes is list && data.adminPinHashes.size() <= 1))
        && (!data.keys().hasAny(['adminNamedPinHashes']) || (data.adminNamedPinHashes is list && data.adminNamedPinHashes.size() <= 50))
        && data.checkinNamedPinHashes is list
        && data.checkinNamedPinHashes.size() <= 50
        && (!data.keys().hasAny(['adminNamedPins']) || (data.adminNamedPins is list && data.adminNamedPins.size() <= 50))
        && data.checkinNamedPins is list
        && data.checkinNamedPins.size() <= 50
        && data.keys().hasOnly([
          'adminPinHash', 'adminPinHashes',
          'adminNamedPinHashes', 'checkinNamedPinHashes',
          'adminNamedPins', 'checkinNamedPins',
          'createdAt', 'updatedAt'
        ]);
    }

    function checkinSecurityUpdateOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'checkinPinHash', 'checkinPinHashes', 'checkinPinValue',
        'checkinNamedPinHashes', 'checkinNamedPins', 'updatedAt'
      ]);
    }

    function newEventSecurityHasNoAdminPins(data) {
      return !data.keys().hasAny([
        'adminPinHash', 'adminPinHashes', 'adminNamedPinHashes', 'adminNamedPins'
      ]);
    }

    function validAdminSecurityData(data) {
      return data.authorizingEventId is string
        && data.createdByUid is string
        && data.adminPinHash is string
        && (!data.keys().hasAny(['adminPinHashes']) || (data.adminPinHashes is list && data.adminPinHashes.size() <= 1))
        && (!data.keys().hasAny(['adminMasterNamedPinHashes']) || (data.adminMasterNamedPinHashes is list && data.adminMasterNamedPinHashes.size() <= 50))
        && (!data.keys().hasAny(['adminNamedPinHashes']) || (data.adminNamedPinHashes is list && data.adminNamedPinHashes.size() <= 50))
        && (!data.keys().hasAny(['adminNamedPins']) || (data.adminNamedPins is list && data.adminNamedPins.size() <= 50))
        && data.keys().hasOnly([
          'authorizingEventId', 'createdByUid',
          'adminPinHash', 'adminPinHashes',
          'adminMasterNamedPinHashes',
          'adminNamedPinHashes', 'adminNamedPins',
          'createdAt', 'updatedAt'
        ]);
    }

    function validMasterAdminForData(data) {
      return data.authorizingEventId is string
        && isMember(data.authorizingEventId)
        && memberData(data.authorizingEventId).role == 'admin'
        && validMasterAdminMemberPinForData(
          data,
          memberData(data.authorizingEventId).pinHash,
          memberData(data.authorizingEventId).pinNameHash,
          memberData(data.authorizingEventId).displayNameKey
        );
    }

    function validGlobalAdminForData(data) {
      return data.authorizingEventId is string
        && isMember(data.authorizingEventId)
        && memberData(data.authorizingEventId).role == 'admin'
        && validAdminMemberPinForData(
          data,
          memberData(data.authorizingEventId).pinHash,
          memberData(data.authorizingEventId).pinNameHash,
          memberData(data.authorizingEventId).displayNameKey
        );
    }

    function isMasterAdmin(eventId) {
      return hasMasterAdminPin(eventId);
    }

    function requestedAdminAuthorizingMember(data) {
      return get(/databases/$(database)/documents/events/$(data.authorizingEventId)/members/$(request.auth.uid)).data;
    }

    function validAdminAuthorizingEventForUpdate(data) {
      return data.authorizingEventId == resource.data.authorizingEventId
        || (
          eventExists(data.authorizingEventId)
          && exists(/databases/$(database)/documents/events/$(data.authorizingEventId)/members/$(request.auth.uid))
          && requestedAdminAuthorizingMember(data).role == 'admin'
          && validMasterAdminForData(resource.data)
        );
    }

    function validEventCreateData(data) {
      return data.name is string
        && data.date is string
        && data.checkinAccessStartsAt is timestamp
        && data.checkinAccessEndsAt is timestamp
        && data.checkinAccessStartsAt < data.checkinAccessEndsAt
        && data.categories is list
        && data.keys().hasOnly([
          'name', 'date', 'checkinAccessStartsAt', 'checkinAccessEndsAt',
          'categories', 'statuses', 'createdAt', 'updatedAt', 'createdByUid'
        ]);
    }

    function eventVisibilityUpdateAllowed(eventId) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'hidden', 'hiddenAt', 'hiddenByUid', 'hiddenByName'
        ])
        || isMasterAdmin(eventId);
    }

    function validGuestData(data) {
      return validStatus(data.status)
        && data.name is string
        && data.category is string
        && data.keys().hasOnly([
          'guestId', 'name', 'searchName', 'category', 'status', 'supportComment', 'adminStaffInfo',
          'checkedInAt', 'checkedInByUid', 'checkedInByName', 'checkedInDevice',
          'createdAt', 'updatedAt', 'createdByUid', 'createdByName',
          'lastActionAt', 'lastActionByName'
        ]);
    }

    function validPartnerLinkData(data) {
      return data.partnerName is string
        && data.partnerName.size() > 0
        && data.partnerName.size() <= 120
        && data.tokenHash is string
        && data.tokenHash.size() == 64
        && data.guestLimit is int
        && data.guestLimit >= 0
        && data.guestLimit <= 5000
        && data.usedCount is int
        && data.usedCount >= 0
        && data.usedCount <= 5000
        && data.active is bool
        && data.expiresAt is timestamp
        && data.counterMutationId is string
        && data.counterMutationKind is string
        && data.createdByUid is string
        && data.createdByName is string
        && data.keys().hasOnly([
          'partnerName', 'tokenHash', 'guestLimit', 'usedCount', 'active', 'expiresAt',
          'counterMutationId', 'counterMutationKind',
          'createdAt', 'updatedAt', 'createdByUid', 'createdByName'
        ]);
    }

    function partnerOwnsSubmission(eventId, data) {
      return isPartner(eventId)
        && data.partnerId == memberData(eventId).partnerId;
    }

    function validPartnerSubmissionData(eventId, data) {
      return data.partnerId is string
        && data.partnerName is string
        && data.partnerName.size() > 0
        && data.partnerName.size() <= 120
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 200
        && data.searchName is string
        && data.category is string
        && data.category in eventData(eventId).categories
        && data.comment is string
        && data.comment.size() <= 1000
        && (data.status == 'pending' || data.status == 'approved' || data.status == 'rejected')
        && (data.guestDocId == null || data.guestDocId is string)
        && data.submittedByUid is string
        && (data.reviewedAt == null || data.reviewedAt is timestamp)
        && (data.reviewedByUid == null || data.reviewedByUid is string)
        && (data.reviewedByName == null || data.reviewedByName is string)
        && data.keys().hasOnly([
          'partnerId', 'partnerName', 'name', 'searchName', 'category', 'comment',
          'status', 'guestDocId', 'submittedByUid', 'createdAt', 'updatedAt',
          'reviewedAt', 'reviewedByUid', 'reviewedByName'
        ]);
    }

    function partnerCounterIncrementAllowed(eventId, partnerId) {
      return isPartner(eventId)
        && partnerId == memberData(eventId).partnerId
        && request.resource.data.usedCount == resource.data.usedCount + 1
        && resource.data.usedCount < resource.data.guestLimit
        && request.resource.data.counterMutationKind == 'create'
        && request.resource.data.counterMutationId is string
        && !exists(/databases/$(database)/documents/events/$(eventId)/partnerSubmissions/$(request.resource.data.counterMutationId))
        && existsAfter(/databases/$(database)/documents/events/$(eventId)/partnerSubmissions/$(request.resource.data.counterMutationId));
    }

    function partnerCounterDecrementAllowed(eventId, partnerId) {
      return isPartner(eventId)
        && partnerId == memberData(eventId).partnerId
        && resource.data.usedCount > 0
        && request.resource.data.usedCount == resource.data.usedCount - 1
        && request.resource.data.counterMutationKind == 'delete'
        && request.resource.data.counterMutationId is string
        && exists(/databases/$(database)/documents/events/$(eventId)/partnerSubmissions/$(request.resource.data.counterMutationId))
        && !existsAfter(/databases/$(database)/documents/events/$(eventId)/partnerSubmissions/$(request.resource.data.counterMutationId));
    }

    function partnerCounterUpdateAllowed(eventId, partnerId) {
      return validPartnerLinkData(request.resource.data)
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'usedCount', 'counterMutationId', 'counterMutationKind', 'updatedAt'
        ])
        && (
          partnerCounterIncrementAllowed(eventId, partnerId)
          || partnerCounterDecrementAllowed(eventId, partnerId)
        );
    }

    function partnerSubmissionCreateAllowed(eventId, submissionId) {
      return partnerOwnsSubmission(eventId, request.resource.data)
        && validPartnerSubmissionData(eventId, request.resource.data)
        && request.resource.data.partnerName == partnerLinkData(eventId, request.resource.data.partnerId).partnerName
        && request.resource.data.status == 'pending'
        && request.resource.data.guestDocId == null
        && request.resource.data.submittedByUid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.reviewedAt == null
        && request.resource.data.reviewedByUid == null
        && request.resource.data.reviewedByName == null
        && getAfter(/databases/$(database)/documents/events/$(eventId)/partnerLinks/$(request.resource.data.partnerId)).data.usedCount
          == partnerLinkData(eventId, request.resource.data.partnerId).usedCount + 1
        && getAfter(/databases/$(database)/documents/events/$(eventId)/partnerLinks/$(request.resource.data.partnerId)).data.counterMutationId == submissionId
        && getAfter(/databases/$(database)/documents/events/$(eventId)/partnerLinks/$(request.resource.data.partnerId)).data.counterMutationKind == 'create';
    }

    function partnerSubmissionUpdateAllowed(eventId) {
      return partnerOwnsSubmission(eventId, resource.data)
        && resource.data.status == 'pending'
        && request.resource.data.status == 'pending'
        && validPartnerSubmissionData(eventId, request.resource.data)
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'searchName', 'category', 'comment', 'updatedAt'
        ]);
    }

    function partnerSubmissionDeleteAllowed(eventId, submissionId) {
      return partnerOwnsSubmission(eventId, resource.data)
        && (
          resource.data.status == 'rejected'
          || (
            resource.data.status == 'pending'
            && getAfter(/databases/$(database)/documents/events/$(eventId)/partnerLinks/$(resource.data.partnerId)).data.usedCount
              == partnerLinkData(eventId, resource.data.partnerId).usedCount - 1
            && getAfter(/databases/$(database)/documents/events/$(eventId)/partnerLinks/$(resource.data.partnerId)).data.counterMutationId == submissionId
            && getAfter(/databases/$(database)/documents/events/$(eventId)/partnerLinks/$(resource.data.partnerId)).data.counterMutationKind == 'delete'
          )
        );
    }

    function validGuestAdminNoteData(data) {
      return data.internalNote is string
        && data.updatedAt == request.time
        && data.updatedByName is string
        && data.keys().hasOnly([
          'internalNote', 'updatedAt', 'updatedByName'
        ]);
    }

    function validGuideId(guideId) {
      return guideId == 'admin' || guideId == 'checkin' || guideId == 'emergency';
    }

    function validGuideData(data) {
      return data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && data.body is string
        && data.body.size() > 0
        && data.body.size() <= 20000
        && data.updatedAt == request.time
        && data.updatedByName is string
        && data.keys().hasOnly([
          'title', 'body', 'updatedAt', 'updatedByName'
        ]);
    }

    function globalGuideWriteAllowed(guideId) {
      return validGuideId(guideId)
        && adminSecurityExists()
        && validMasterAdminForData(adminSecurityData());
    }

    function staffGuestUpdateAllowed(eventId) {
      return isCheckin(eventId) && (
        (
          request.resource.data.supportComment is string
          && request.resource.data.updatedAt == request.time
          && request.resource.data.lastActionAt == request.time
          && request.resource.data.lastActionByName is string
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'supportComment', 'updatedAt', 'lastActionAt', 'lastActionByName'
          ])
        )
        ||
        (
          resource.data.status != 'checked_in'
          && request.resource.data.status == 'checked_in'
          && request.resource.data.checkedInByUid == request.auth.uid
          && request.resource.data.checkedInAt == request.time
          && request.resource.data.updatedAt == request.time
          && request.resource.data.lastActionAt == request.time
          && request.resource.data.checkedInByName is string
          && request.resource.data.checkedInDevice is string
          && request.resource.data.lastActionByName is string
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'checkedInAt', 'checkedInByUid', 'checkedInByName', 'checkedInDevice',
            'updatedAt', 'lastActionAt', 'lastActionByName', 'supportComment'
          ])
        )
        ||
        (
          resource.data.status == 'checked_in'
          && resource.data.checkedInByUid == request.auth.uid
          && resource.data.checkedInAt is timestamp
          && request.time < resource.data.checkedInAt + duration.value(1, 'm')
          && request.resource.data.status == 'open'
          && request.resource.data.checkedInAt == null
          && request.resource.data.checkedInByUid == null
          && request.resource.data.checkedInByName == null
          && request.resource.data.checkedInDevice == null
          && request.resource.data.updatedAt == request.time
          && request.resource.data.lastActionAt == request.time
          && request.resource.data.lastActionByName is string
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'checkedInAt', 'checkedInByUid', 'checkedInByName', 'checkedInDevice',
            'updatedAt', 'lastActionAt', 'lastActionByName'
          ])
        )
      );
    }

    match /appSecurity/{docId} {
      allow get: if docId == 'admin'
        && signedIn()
        && (
          !adminSecurityExists()
          || validMasterAdminForData(resource.data)
        );
      allow list: if false;
      allow create: if docId == 'admin'
        && signedIn()
        && !adminSecurityExists()
        && request.resource.data.createdByUid == request.auth.uid
        && validAdminSecurityData(request.resource.data)
        && validLegacyMasterAdminForData(request.resource.data);
      allow update: if docId == 'admin'
        && adminSecurityExists()
        && validMasterAdminForData(resource.data)
        && request.resource.data.createdByUid == resource.data.createdByUid
        && validAdminSecurityData(request.resource.data)
        && validAdminAuthorizingEventForUpdate(request.resource.data);
      allow delete: if false;
    }

    match /appGuides/{guideId} {
      allow get: if signedIn()
        && validGuideId(guideId);
      allow list: if false;
      allow create, update: if globalGuideWriteAllowed(guideId)
        && validGuideData(request.resource.data);
      allow delete: if globalGuideWriteAllowed(guideId);
    }

    match /events/{eventId} {
      // The event document intentionally contains only public event metadata.
      allow get: if true;
      allow list: if signedIn()
        && adminSecurityExists()
        && validGlobalAdminForData(adminSecurityData());

      allow create: if signedIn()
        && isAdmin(eventId)
        && request.resource.data.createdByUid == request.auth.uid
        && validEventCreateData(request.resource.data);

      allow update: if isAdmin(eventId)
        && eventVisibilityUpdateAllowed(eventId);
      allow delete: if isMasterAdmin(eventId);

      match /private/{docId} {
        allow get: if isAdmin(eventId);
        allow update: if isAdmin(eventId)
          && docId == 'security'
          && validSecurityData(request.resource.data)
          && checkinSecurityUpdateOnly();
        allow delete: if isMasterAdmin(eventId)
          && docId == 'security';
        allow list: if false;

        // Initial security document can only be created by the anonymous user that created the event.
        allow create: if signedIn()
          && docId == 'security'
          && eventExists(eventId)
          && eventData(eventId).createdByUid == request.auth.uid
          && !securityExists(eventId)
          && validSecurityData(request.resource.data)
          && newEventSecurityHasNoAdminPins(request.resource.data);
      }

      match /members/{uid} {
        allow get: if (signedIn() && uid == request.auth.uid) || isAdmin(eventId) || sameNamedMember(eventId);
        allow list: if isAdmin(eventId) || sameNamedMember(eventId);
        allow create: if validMemberCreate(eventId, uid);
        allow update: if validMemberSelfUpdate(eventId, uid);
        allow update: if adminMemberDeviceLabelUpdateAllowed(eventId);
        allow delete: if isAdmin(eventId) || (signedIn() && uid == request.auth.uid) || sameNamedOtherMember(eventId, uid);
      }

      match /partnerLinks/{partnerId} {
        allow read: if isAdmin(eventId)
          || (isPartner(eventId) && partnerId == memberData(eventId).partnerId);
        allow create: if isAdmin(eventId)
          && validPartnerLinkData(request.resource.data)
          && request.resource.data.createdByUid == request.auth.uid
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time;
        allow update: if (
            isAdmin(eventId)
            && validPartnerLinkData(request.resource.data)
            && request.resource.data.createdByUid == resource.data.createdByUid
          )
          || partnerCounterUpdateAllowed(eventId, partnerId);
        allow delete: if isAdmin(eventId);
      }

      match /partnerSubmissions/{submissionId} {
        allow read: if isAdmin(eventId)
          || partnerOwnsSubmission(eventId, resource.data);
        allow create: if partnerSubmissionCreateAllowed(eventId, submissionId);
        allow update: if (
            isAdmin(eventId)
            && validPartnerSubmissionData(eventId, request.resource.data)
          )
          || partnerSubmissionUpdateAllowed(eventId);
        allow delete: if isAdmin(eventId)
          || partnerSubmissionDeleteAllowed(eventId, submissionId);
      }

      match /guests/{guestId} {
        allow read: if isCheckin(eventId);
        allow create: if isAdmin(eventId)
          && validGuestData(request.resource.data);

        allow update: if (isAdmin(eventId) && validGuestData(request.resource.data))
          || staffGuestUpdateAllowed(eventId);
        allow delete: if isAdmin(eventId);
      }

      match /guestAdminNotes/{guestId} {
        allow read: if isAdmin(eventId);
        allow create, update: if isAdmin(eventId)
          && validGuestAdminNoteData(request.resource.data);
        allow delete: if isAdmin(eventId);
      }

      match /auditLog/{logId} {
        allow read: if isCheckin(eventId);
        allow create: if isCheckin(eventId)
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.action is string
          && request.resource.data.keys().hasOnly([
            'action', 'guestDocId', 'guestId', 'guestName', 'category', 'details',
            'actorUid', 'actorName', 'deviceLabel', 'createdAt'
          ]);
        allow update: if false;
        allow delete: if isMasterAdmin(eventId);
      }
    }
  }
}
