rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function eventExists(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId));
    }

    function eventData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)).data;
    }

    function securityExists(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId)/private/security);
    }

    function securityData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/private/security).data;
    }

    function adminSecurityExists() {
      return exists(/databases/$(database)/documents/appSecurity/admin);
    }

    function adminSecurityData() {
      return get(/databases/$(database)/documents/appSecurity/admin).data;
    }

    function isMember(eventId) {
      return signedIn()
        && exists(/databases/$(database)/documents/events/$(eventId)/members/$(request.auth.uid));
    }

    function memberData(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId)/members/$(request.auth.uid)).data;
    }

    function validRole(role) {
      return role == 'admin' || role == 'checkin';
    }

    function validAdminPinForData(data, pinHash, pinNameHash) {
      return data.adminPinHash == pinHash
        || (
          data.keys().hasAny(['adminPinHashes'])
          && pinHash in data.adminPinHashes
        )
        || (
          pinNameHash is string
          && data.keys().hasAny(['adminNamedPinHashes'])
          && pinNameHash in data.adminNamedPinHashes
        );
    }

    function validMasterAdminPinForData(data, pinHash, pinNameHash) {
      return data.adminPinHash == pinHash
        || (
          data.keys().hasAny(['adminPinHashes'])
          && pinHash in data.adminPinHashes
        )
        || (
          pinNameHash is string
          && data.keys().hasAny(['adminMasterNamedPinHashes'])
          && pinNameHash in data.adminMasterNamedPinHashes
        );
    }

    function validLegacyAdminPin(eventId, pinHash, pinNameHash) {
      return securityExists(eventId)
        && (
          securityData(eventId).adminPinHash == pinHash
          || (
            securityData(eventId).keys().hasAny(['adminPinHashes'])
            && pinHash in securityData(eventId).adminPinHashes
          )
          || (
            pinNameHash is string
            && securityData(eventId).keys().hasAny(['adminNamedPinHashes'])
            && pinNameHash in securityData(eventId).adminNamedPinHashes
          )
        );
    }

    function validLegacyMasterAdminForData(data) {
      return data.authorizingEventId is string
        && isMember(data.authorizingEventId)
        && memberData(data.authorizingEventId).role == 'admin'
        && validLegacyAdminPin(data.authorizingEventId, memberData(data.authorizingEventId).pinHash, '');
    }

    function validAdminPin(eventId, pinHash, pinNameHash) {
      return (
          adminSecurityExists()
          && validAdminPinForData(adminSecurityData(), pinHash, pinNameHash)
        )
        || (
          !adminSecurityExists()
          && validLegacyAdminPin(eventId, pinHash, pinNameHash)
        );
    }

    function validCheckinPin(eventId, pinHash, pinNameHash) {
      return securityExists(eventId)
        && (
          securityData(eventId).checkinPinHash == pinHash
          || (
            securityData(eventId).keys().hasAny(['checkinPinHashes'])
            && pinHash in securityData(eventId).checkinPinHashes
          )
          || (
            pinNameHash is string
            && securityData(eventId).keys().hasAny(['checkinNamedPinHashes'])
            && pinNameHash in securityData(eventId).checkinNamedPinHashes
          )
        );
    }

    function validPin(eventId, role, pinHash, pinNameHash) {
      return (
          role == 'admin'
          && validAdminPin(eventId, pinHash, pinNameHash)
        )
        || (
          role == 'checkin'
          && validCheckinPin(eventId, pinHash, pinNameHash)
        );
    }

    function hasCurrentPin(eventId) {
      return isMember(eventId)
        && (
          validPin(eventId, memberData(eventId).role, memberData(eventId).pinHash, '')
          || (
            memberData(eventId).keys().hasAny(['pinNameHash'])
            && validPin(eventId, memberData(eventId).role, memberData(eventId).pinHash, memberData(eventId).pinNameHash)
          )
        );
    }

    function eventHidden(eventId) {
      return eventExists(eventId)
        && eventData(eventId).keys().hasAny(['hidden'])
        && eventData(eventId).hidden == true;
    }

    function hasMasterAdminPin(eventId) {
      return hasCurrentPin(eventId)
        && memberData(eventId).role == 'admin'
        && adminSecurityExists()
        && validMasterAdminPinForData(adminSecurityData(), memberData(eventId).pinHash, memberData(eventId).pinNameHash);
    }

    function isAdmin(eventId) {
      return hasCurrentPin(eventId)
        && memberData(eventId).role == 'admin';
    }

    function checkinAccessWindowOpen(eventId) {
      return eventExists(eventId)
        && !eventHidden(eventId)
        && eventData(eventId).keys().hasAll(['checkinAccessStartsAt', 'checkinAccessEndsAt'])
        && eventData(eventId).checkinAccessStartsAt is timestamp
        && eventData(eventId).checkinAccessEndsAt is timestamp
        && request.time >= eventData(eventId).checkinAccessStartsAt
        && request.time < eventData(eventId).checkinAccessEndsAt;
    }

    function isCheckin(eventId) {
      return isAdmin(eventId)
        || (
          hasCurrentPin(eventId)
          && memberData(eventId).role == 'checkin'
          && checkinAccessWindowOpen(eventId)
        );
    }

    function memberWriteAllowedForRole(eventId, role) {
      return role == 'admin'
        || (
          role == 'checkin'
          && checkinAccessWindowOpen(eventId)
        );
    }

    function sameNamedMember(eventId) {
      return isCheckin(eventId)
        && resource.data.role == memberData(eventId).role
        && resource.data.displayNameKey is string
        && resource.data.displayNameKey != ''
        && resource.data.displayNameKey == memberData(eventId).displayNameKey;
    }

    function sameNamedOtherMember(eventId, uid) {
      return signedIn()
        && uid != request.auth.uid
        && sameNamedMember(eventId);
    }

    function adminMemberDeviceLabelUpdateAllowed(eventId) {
      return isAdmin(eventId)
        && request.resource.data.deviceLabel is string
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'deviceLabel', 'updatedAt'
        ]);
    }

    function validMemberWrite(eventId, uid) {
      return signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && validRole(request.resource.data.role)
        && request.resource.data.pinHash is string
        && request.resource.data.pinNameHash is string
        && request.resource.data.displayNameKey is string
        && request.resource.data.displayName is string
        && request.resource.data.deviceLabel is string
        && validPin(eventId, request.resource.data.role, request.resource.data.pinHash, request.resource.data.pinNameHash)
        && memberWriteAllowedForRole(eventId, request.resource.data.role)
        && request.resource.data.keys().hasOnly([
          'uid', 'role', 'pinHash', 'pinNameHash', 'displayNameKey',
          'displayName', 'deviceLabel', 'createdAt', 'updatedAt'
        ]);
    }

    function validMemberCreate(eventId, uid) {
      return validMemberWrite(eventId, uid);
    }

    function validMemberSelfUpdate(eventId, uid) {
      return validMemberWrite(eventId, uid);
    }

    function validStatus(status) {
      return status == 'open' || status == 'checked_in' || status == 'no_show';
    }

    function validSecurityData(data) {
      return data.checkinPinHash is string
        && (!data.keys().hasAny(['adminPinHash']) || data.adminPinHash is string)
        && (!data.keys().hasAny(['adminPinHashes']) || (data.adminPinHashes is list && data.adminPinHashes.size() <= 1))
        && (!data.keys().hasAny(['checkinPinHashes']) || (data.checkinPinHashes is list && data.checkinPinHashes.size() <= 1))
        && (!data.keys().hasAny(['checkinPinValue']) || data.checkinPinValue is string)
        && (!data.keys().hasAny(['adminNamedPinHashes']) || (data.adminNamedPinHashes is list && data.adminNamedPinHashes.size() <= 50))
        && (!data.keys().hasAny(['checkinNamedPinHashes']) || (data.checkinNamedPinHashes is list && data.checkinNamedPinHashes.size() <= 50))
        && (!data.keys().hasAny(['adminNamedPins']) || (data.adminNamedPins is list && data.adminNamedPins.size() <= 50))
        && (!data.keys().hasAny(['checkinNamedPins']) || (data.checkinNamedPins is list && data.checkinNamedPins.size() <= 50))
        && data.keys().hasOnly([
          'adminPinHash', 'checkinPinHash',
          'adminPinHashes', 'checkinPinHashes', 'checkinPinValue',
          'adminNamedPinHashes', 'checkinNamedPinHashes',
          'adminNamedPins', 'checkinNamedPins',
          'createdAt', 'updatedAt'
        ]);
    }

    function checkinSecurityUpdateOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'checkinPinHash', 'checkinPinHashes', 'checkinPinValue',
        'checkinNamedPinHashes', 'checkinNamedPins', 'updatedAt'
      ]);
    }

    function newEventSecurityHasNoAdminPins(data) {
      return !data.keys().hasAny([
        'adminPinHash', 'adminPinHashes', 'adminNamedPinHashes', 'adminNamedPins'
      ]);
    }

    function validAdminSecurityData(data) {
      return data.authorizingEventId is string
        && data.createdByUid is string
        && data.adminPinHash is string
        && (!data.keys().hasAny(['adminPinHashes']) || (data.adminPinHashes is list && data.adminPinHashes.size() <= 1))
        && (!data.keys().hasAny(['adminMasterNamedPinHashes']) || (data.adminMasterNamedPinHashes is list && data.adminMasterNamedPinHashes.size() <= 50))
        && (!data.keys().hasAny(['adminNamedPinHashes']) || (data.adminNamedPinHashes is list && data.adminNamedPinHashes.size() <= 50))
        && (!data.keys().hasAny(['adminNamedPins']) || (data.adminNamedPins is list && data.adminNamedPins.size() <= 50))
        && data.keys().hasOnly([
          'authorizingEventId', 'createdByUid',
          'adminPinHash', 'adminPinHashes',
          'adminMasterNamedPinHashes',
          'adminNamedPinHashes', 'adminNamedPins',
          'createdAt', 'updatedAt'
        ]);
    }

    function validMasterAdminForData(data) {
      return data.authorizingEventId is string
        && isMember(data.authorizingEventId)
        && memberData(data.authorizingEventId).role == 'admin'
        && validMasterAdminPinForData(data, memberData(data.authorizingEventId).pinHash, memberData(data.authorizingEventId).pinNameHash);
    }

    function validGlobalAdminForData(data) {
      return data.authorizingEventId is string
        && isMember(data.authorizingEventId)
        && memberData(data.authorizingEventId).role == 'admin'
        && (
          validAdminPinForData(data, memberData(data.authorizingEventId).pinHash, '')
          || (
            memberData(data.authorizingEventId).keys().hasAny(['pinNameHash'])
            && validAdminPinForData(data, memberData(data.authorizingEventId).pinHash, memberData(data.authorizingEventId).pinNameHash)
          )
        );
    }

    function isMasterAdmin(eventId) {
      return hasMasterAdminPin(eventId);
    }

    function requestedAdminAuthorizingMember(data) {
      return get(/databases/$(database)/documents/events/$(data.authorizingEventId)/members/$(request.auth.uid)).data;
    }

    function validAdminAuthorizingEventForUpdate(data) {
      return data.authorizingEventId == resource.data.authorizingEventId
        || (
          eventExists(data.authorizingEventId)
          && exists(/databases/$(database)/documents/events/$(data.authorizingEventId)/members/$(request.auth.uid))
          && requestedAdminAuthorizingMember(data).role == 'admin'
          && validMasterAdminForData(resource.data)
        );
    }

    function validEventCreateData(data) {
      return data.name is string
        && data.date is string
        && data.checkinAccessStartsAt is timestamp
        && data.checkinAccessEndsAt is timestamp
        && data.checkinAccessStartsAt < data.checkinAccessEndsAt
        && data.categories is list
        && data.keys().hasOnly([
          'name', 'date', 'checkinAccessStartsAt', 'checkinAccessEndsAt',
          'categories', 'statuses', 'createdAt', 'updatedAt', 'createdByUid'
        ]);
    }

    function eventVisibilityUpdateAllowed(eventId) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'hidden', 'hiddenAt', 'hiddenByUid', 'hiddenByName'
        ])
        || isMasterAdmin(eventId);
    }

    function validGuestData(data) {
      return validStatus(data.status)
        && data.name is string
        && data.category is string
        && data.keys().hasOnly([
          'guestId', 'name', 'searchName', 'category', 'status', 'supportComment', 'adminStaffInfo',
          'checkedInAt', 'checkedInByUid', 'checkedInByName', 'checkedInDevice',
          'createdAt', 'updatedAt', 'createdByUid', 'createdByName',
          'lastActionAt', 'lastActionByName'
        ]);
    }

    function validGuestAdminNoteData(data) {
      return data.internalNote is string
        && data.updatedAt == request.time
        && data.updatedByName is string
        && data.keys().hasOnly([
          'internalNote', 'updatedAt', 'updatedByName'
        ]);
    }

    function staffGuestUpdateAllowed(eventId) {
      return isCheckin(eventId) && (
        (
          request.resource.data.supportComment is string
          && request.resource.data.updatedAt == request.time
          && request.resource.data.lastActionAt == request.time
          && request.resource.data.lastActionByName is string
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'supportComment', 'updatedAt', 'lastActionAt', 'lastActionByName'
          ])
        )
        ||
        (
          resource.data.status != 'checked_in'
          && request.resource.data.status == 'checked_in'
          && request.resource.data.checkedInByUid == request.auth.uid
          && request.resource.data.checkedInAt == request.time
          && request.resource.data.updatedAt == request.time
          && request.resource.data.lastActionAt == request.time
          && request.resource.data.checkedInByName is string
          && request.resource.data.checkedInDevice is string
          && request.resource.data.lastActionByName is string
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'checkedInAt', 'checkedInByUid', 'checkedInByName', 'checkedInDevice',
            'updatedAt', 'lastActionAt', 'lastActionByName', 'supportComment'
          ])
        )
        ||
        (
          resource.data.status == 'checked_in'
          && resource.data.checkedInByUid == request.auth.uid
          && (request.resource.data.status == 'open' || request.resource.data.status == 'no_show')
          && request.resource.data.checkedInAt == null
          && request.resource.data.checkedInByUid == null
          && request.resource.data.checkedInByName == null
          && request.resource.data.checkedInDevice == null
          && request.resource.data.updatedAt == request.time
          && request.resource.data.lastActionAt == request.time
          && request.resource.data.lastActionByName is string
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'checkedInAt', 'checkedInByUid', 'checkedInByName', 'checkedInDevice',
            'updatedAt', 'lastActionAt', 'lastActionByName'
          ])
        )
      );
    }

    match /appSecurity/{docId} {
      allow get: if docId == 'admin'
        && signedIn()
        && (
          !adminSecurityExists()
          || validMasterAdminForData(resource.data)
        );
      allow list: if false;
      allow create: if docId == 'admin'
        && signedIn()
        && !adminSecurityExists()
        && request.resource.data.createdByUid == request.auth.uid
        && validAdminSecurityData(request.resource.data)
        && validLegacyMasterAdminForData(request.resource.data);
      allow update: if docId == 'admin'
        && adminSecurityExists()
        && validMasterAdminForData(resource.data)
        && request.resource.data.createdByUid == resource.data.createdByUid
        && validAdminSecurityData(request.resource.data)
        && validAdminAuthorizingEventForUpdate(request.resource.data);
      allow delete: if false;
    }

    match /events/{eventId} {
      // The event document intentionally contains only public event metadata.
      allow get: if true;
      allow list: if signedIn()
        && adminSecurityExists()
        && validGlobalAdminForData(adminSecurityData());

      allow create: if signedIn()
        && isAdmin(eventId)
        && request.resource.data.createdByUid == request.auth.uid
        && validEventCreateData(request.resource.data);

      allow update: if isAdmin(eventId)
        && eventVisibilityUpdateAllowed(eventId);
      allow delete: if isMasterAdmin(eventId);

      match /private/{docId} {
        allow get: if isAdmin(eventId);
        allow update: if isAdmin(eventId)
          && docId == 'security'
          && validSecurityData(request.resource.data)
          && checkinSecurityUpdateOnly();
        allow delete: if isMasterAdmin(eventId)
          && docId == 'security';
        allow list: if false;

        // Initial security document can only be created by the anonymous user that created the event.
        allow create: if signedIn()
          && docId == 'security'
          && eventExists(eventId)
          && eventData(eventId).createdByUid == request.auth.uid
          && !securityExists(eventId)
          && validSecurityData(request.resource.data)
          && newEventSecurityHasNoAdminPins(request.resource.data);
      }

      match /members/{uid} {
        allow get: if (signedIn() && uid == request.auth.uid) || isAdmin(eventId) || sameNamedMember(eventId);
        allow list: if isAdmin(eventId) || sameNamedMember(eventId);
        allow create: if validMemberCreate(eventId, uid);
        allow update: if validMemberSelfUpdate(eventId, uid);
        allow update: if adminMemberDeviceLabelUpdateAllowed(eventId);
        allow delete: if isAdmin(eventId) || (signedIn() && uid == request.auth.uid) || sameNamedOtherMember(eventId, uid);
      }

      match /guests/{guestId} {
        allow read: if isCheckin(eventId);
        allow create: if isAdmin(eventId)
          && validGuestData(request.resource.data);

        allow update: if (isAdmin(eventId) && validGuestData(request.resource.data))
          || staffGuestUpdateAllowed(eventId);
        allow delete: if isAdmin(eventId);
      }

      match /guestAdminNotes/{guestId} {
        allow read: if isAdmin(eventId);
        allow create, update: if isAdmin(eventId)
          && validGuestAdminNoteData(request.resource.data);
        allow delete: if isAdmin(eventId);
      }

      match /auditLog/{logId} {
        allow read: if isCheckin(eventId);
        allow create: if isCheckin(eventId)
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.action is string
          && request.resource.data.keys().hasOnly([
            'action', 'guestDocId', 'guestId', 'guestName', 'category', 'details',
            'actorUid', 'actorName', 'deviceLabel', 'createdAt'
          ]);
        allow update: if false;
        allow delete: if isMasterAdmin(eventId);
      }
    }
  }
}
